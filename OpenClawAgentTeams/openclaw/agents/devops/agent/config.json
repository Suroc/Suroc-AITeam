{
  // DevOps Agent — 测试/部署/运维工程师的独立配置
  model: "anthropic/claude-sonnet-4-6",

  // 沙箱：启用，独立容器，包含完整工具链
  sandbox: {
    mode: "all",
    scope: "agent",
    docker: {
      setupCommand: "apt-get update && apt-get install -y git nodejs npm curl wget docker.io python3 python3-pip"
    }
  },

  tools: {
    allow: [
      "agent-send",
      "web-browse",
      "web-search",
      "memory-read",
      "memory-write",
      "file-read",
      "file-write",
      "code-execute",
      "shell",
      "docker"              // DevOps拥有Docker权限
    ],
    deny: []
  },

  memory: {
    engine: "builtin",
    persistent: true
  }
}
